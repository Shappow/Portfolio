---
import type { TechKind } from '../../utils/techKind';

interface Props {
  label: string;
  kind?: TechKind;
}

const { label, kind = 'tool' } = Astro.props;

const styles: Record<TechKind, string> = {
  lang: 'background: rgba(0,212,184,0.10); color: var(--accent-teal);   border: 1px solid rgba(0,212,184,0.25);',
  tool: 'background: rgba(96,165,250,0.10); color: #60A5FA;              border: 1px solid rgba(96,165,250,0.25);',
  hw:   'background: rgba(245,158,11,0.10); color: #F59E0B;              border: 1px solid rgba(245,158,11,0.25);',
};
---

<span class="inline-block font-mono text-[11px] px-2 py-0.5 rounded" style={styles[kind]}>
  {label}
</span>
