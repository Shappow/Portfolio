---
// Modal partagé pour les cartes projets et passions
---

<div id="card-modal-overlay" style="display:none; position:fixed; inset:0; z-index:200; align-items:center; justify-content:center; padding:1rem; background:rgba(0,0,0,0.7); backdrop-filter:blur(4px);">
  <div
    id="card-modal"
    class="bento-card"
    style="position:relative; width:100%; max-width:680px; max-height:85vh; overflow-y:auto; padding:0;"
  >
    <!-- Header -->
    <div id="modal-header" style="position:sticky; top:0; z-index:10; padding:1.25rem 1.25rem 1rem; border-bottom:1px solid var(--border); background:var(--bg-surface); backdrop-filter:blur(12px);">
      <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.75rem;">
        <div style="flex:1; min-width:0;">
          <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.25rem;">
            <span id="modal-id" style="font-family:monospace; font-size:0.65rem; color:var(--accent-dim);"></span>
            <span id="modal-status" style="font-family:monospace; font-size:0.6rem; padding:0.1rem 0.4rem; border-radius:9999px;"></span>
          </div>
          <h2 id="modal-title" style="font-family:monospace; font-size:1rem; font-weight:700; color:var(--text-primary); line-height:1.3;"></h2>
          <div style="display:flex; align-items:center; gap:0.5rem; margin-top:0.35rem;">
            <span id="modal-type" style="font-family:monospace; font-size:0.6rem; padding:0.15rem 0.5rem; border-radius:4px;"></span>
            <span id="modal-ref" style="font-family:monospace; font-size:0.7rem; font-weight:600;"></span>
          </div>
        </div>
        <button
          id="modal-close"
          aria-label="Fermer"
          style="flex-shrink:0; width:2rem; height:2rem; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.1rem; background:var(--bg-surface-2); border:1px solid var(--border); color:var(--text-muted); cursor:pointer;"
        >×</button>
      </div>
    </div>

    <!-- Body -->
    <div style="padding:1.25rem; display:flex; flex-direction:column; gap:1rem;">

      <!-- Image -->
      <img id="modal-image" src="" alt="" style="display:none; width:100%; border-radius:6px; max-height:280px; object-fit:contain;" />

      <!-- Description -->
      <p id="modal-description" style="font-size:0.8rem; line-height:1.6; color:var(--text-secondary);"></p>

      <!-- Contexte -->
      <div id="modal-context-block" style="display:none;">
        <p style="font-family:monospace; font-size:0.65rem; color:var(--accent-dim); margin-bottom:0.35rem;">// contexte</p>
        <p id="modal-context" style="font-size:0.75rem; line-height:1.6; color:var(--text-secondary); padding:0.75rem; border-radius:6px; background:var(--bg-surface-2); border:1px solid var(--border);"></p>
      </div>

      <!-- Objectifs -->
      <div id="modal-objectives-block" style="display:none;">
        <p style="font-family:monospace; font-size:0.65rem; color:var(--accent-dim); margin-bottom:0.35rem;">// objectifs[]</p>
        <ul id="modal-objectives" style="display:flex; flex-direction:column; gap:0.4rem; list-style:none; padding:0; margin:0;"></ul>
      </div>

      <!-- Détails techniques -->
      <div id="modal-technical-block" style="display:none;">
        <p style="font-family:monospace; font-size:0.65rem; color:var(--accent-teal); margin-bottom:0.35rem;">// technical_stack[]</p>
        <ul id="modal-technical" style="display:flex; flex-direction:column; gap:0.4rem; list-style:none; padding:0; margin:0;"></ul>
      </div>

      <!-- Résultats -->
      <div id="modal-results-block" style="display:none;">
        <p style="font-family:monospace; font-size:0.65rem; color:#4ADE80; margin-bottom:0.35rem;">// results[]</p>
        <ul id="modal-results" style="display:flex; flex-direction:column; gap:0.4rem; list-style:none; padding:0; margin:0;"></ul>
      </div>

      <!-- Stack -->
      <div id="modal-stack-block" style="display:none;">
        <p style="font-family:monospace; font-size:0.65rem; color:var(--accent-dim); margin-bottom:0.4rem;">// stack</p>
        <div id="modal-stack" style="display:flex; flex-wrap:wrap; gap:0.35rem;"></div>
      </div>

      <!-- Liens documents -->
      <div id="modal-docs-block" style="display:none;">
        <p style="font-family:monospace; font-size:0.65rem; color:var(--accent-dim); margin-bottom:0.4rem;">// documents</p>
        <div id="modal-docs" style="display:flex; flex-wrap:wrap; gap:0.5rem;"></div>
      </div>

      <!-- Liens externes -->
      <div id="modal-links-block" style="display:none;">
        <p style="font-family:monospace; font-size:0.65rem; color:var(--accent-dim); margin-bottom:0.4rem;">// links</p>
        <div id="modal-links" style="display:flex; flex-wrap:wrap; gap:0.5rem;"></div>
      </div>

    </div>
  </div>
</div>

<script>
  const overlay  = document.getElementById('card-modal-overlay')!;
  const modal    = document.getElementById('card-modal')!;
  const closeBtn = document.getElementById('modal-close')!;

  function show(show: boolean) {
    overlay.style.display = show ? 'flex' : 'none';
    document.body.style.overflow = show ? 'hidden' : '';
  }

  function setText(id: string, val: string | undefined) {
    const el = document.getElementById(id);
    if (el) el.textContent = val ?? '';
  }

  function setList(blockId: string, listId: string, items: string[] | undefined, color: string) {
    const block = document.getElementById(blockId)!;
    const list  = document.getElementById(listId)!;
    if (!items?.length) { block.style.display = 'none'; return; }
    block.style.display = 'block';
    list.innerHTML = items.map(item => `
      <li style="display:flex; gap:0.5rem; font-size:0.75rem; color:var(--text-secondary);">
        <span style="color:${color}; flex-shrink:0; margin-top:0.05rem;">▸</span>
        <span>${item}</span>
      </li>`).join('');
  }

  function setLinks(blockId: string, containerId: string, links: {label:string;href:string}[] | undefined, download=false) {
    const block = document.getElementById(blockId)!;
    const cont  = document.getElementById(containerId)!;
    if (!links?.length) { block.style.display = 'none'; return; }
    block.style.display = 'block';
    cont.innerHTML = links.map(l => `
      <a href="${l.href}" ${download ? 'download' : 'target="_blank" rel="noopener noreferrer"'}
        style="font-family:monospace; font-size:0.7rem; padding:0.3rem 0.75rem; border-radius:4px; border:1px solid var(--border); color:var(--accent-teal); text-decoration:none; display:inline-flex; align-items:center; gap:0.3rem; background:var(--bg-surface-2);"
        onmouseover="this.style.borderColor='var(--accent-teal)'"
        onmouseout="this.style.borderColor='var(--border)'"
      >${download ? '↓' : '→'} ${l.label}</a>`).join('');
  }

  // Badge helpers
  function typeStyle(type: string) {
    if (type === 'perso') return 'background:rgba(0,212,184,.1);color:var(--accent-teal);border:1px solid rgba(0,212,184,.25);';
    if (type === 'pro')   return 'background:rgba(245,158,11,.1);color:#F59E0B;border:1px solid rgba(245,158,11,.3);';
    return 'background:rgba(96,165,250,.1);color:#60A5FA;border:1px solid rgba(96,165,250,.3);';
  }
  function typeLabel(type: string) {
    if (type === 'perso') return 'Personnel';
    if (type === 'pro')   return 'Professionnel';
    return 'Académique';
  }
  function statusStyle(s: string) {
    if (s === 'stable')   return 'background:rgba(74,222,128,.15);color:#4ADE80;border:1px solid rgba(74,222,128,.3);';
    if (s === 'wip')      return 'background:rgba(245,158,11,.15);color:#F59E0B;border:1px solid rgba(245,158,11,.3);';
    return 'background:rgba(126,184,176,.1);color:var(--text-muted);border:1px solid var(--border);';
  }

  // Badge factory pour tech stack
  function techBadge(label: string) {
    return `<span style="font-family:monospace; font-size:0.65rem; padding:0.15rem 0.5rem; border-radius:4px; background:rgba(96,165,250,.1); color:#60A5FA; border:1px solid rgba(96,165,250,.25);">${label}</span>`;
  }

  (window as any).openCardModal = function(data: any) {
    modal.scrollTop = 0;

    // Header
    setText('modal-id', data.id ?? '');
    setText('modal-title', data.title);

    const statusEl = document.getElementById('modal-status')!;
    statusEl.textContent = (data.status ?? '').toUpperCase();
    statusEl.style.cssText += statusStyle(data.status ?? '');

    const typeEl = document.getElementById('modal-type')!;
    typeEl.textContent = typeLabel(data.type ?? '');
    typeEl.style.cssText += typeStyle(data.type ?? '');
    typeEl.style.display = data.type ? 'inline' : 'none';

    const refEl = document.getElementById('modal-ref')!;
    refEl.textContent = data.ref ?? '';
    refEl.style.color = data.color ?? 'var(--accent-teal)';
    refEl.style.display = data.ref ? 'inline' : 'none';

    // Image
    const imgEl = document.getElementById('modal-image') as HTMLImageElement;
    if (data.image) {
      imgEl.src = data.image;
      imgEl.alt = data.title;
      imgEl.style.display = 'block';
    } else {
      imgEl.style.display = 'none';
    }

    // Description
    setText('modal-description', data.description);

    // Details
    const d = data.details ?? {};

    const ctxBlock = document.getElementById('modal-context-block')!;
    if (d.context) {
      ctxBlock.style.display = 'block';
      setText('modal-context', d.context);
    } else { ctxBlock.style.display = 'none'; }

    setList('modal-objectives-block', 'modal-objectives', d.objectives, 'var(--accent-dim)');
    setList('modal-technical-block',  'modal-technical',  d.technical,  'var(--accent-teal)');
    setList('modal-results-block',    'modal-results',    d.results,    '#4ADE80');

    // Stack
    const stackBlock = document.getElementById('modal-stack-block')!;
    const stackCont  = document.getElementById('modal-stack')!;
    if (data.stack?.length) {
      stackBlock.style.display = 'block';
      stackCont.innerHTML = data.stack.map(techBadge).join('');
    } else { stackBlock.style.display = 'none'; }

    setLinks('modal-docs-block',  'modal-docs',  d.docs,  true);
    setLinks('modal-links-block', 'modal-links', d.links, false);

    show(true);
  };

  closeBtn.addEventListener('click', () => show(false));
  overlay.addEventListener('click', (e) => { if (e.target === overlay) show(false); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') show(false); });
</script>
