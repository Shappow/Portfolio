---
interface Props {
  id: string;
  label: string;
  comment?: string;
}

const { id, label, comment } = Astro.props;
---

<div class="flex items-center gap-4 mb-8">
  <span class="font-mono text-xs" style="color: var(--accent-dim);">// {id.toUpperCase()}</span>
  <h2 class="font-mono text-xl font-bold" style="color: var(--text-primary);">{label}</h2>
  {comment && (
    <span class="font-mono text-xs hidden sm:inline" style="color: var(--text-muted);">/* {comment} */</span>
  )}
  <div class="flex-1 h-px" style="background: linear-gradient(90deg, var(--border), transparent);"></div>
</div>
