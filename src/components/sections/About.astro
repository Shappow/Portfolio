---
import BentoCard from '../ui/BentoCard.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import AnimationWrapper from '../ui/AnimationWrapper.astro';

const stats = [
  { label: 'Projets réalisés',     value: '6',  page: 'projects'    },
  { label: 'Langages de prog.',    value: '5+', page: 'competences' },
  { label: 'Formations suivies',   value: '4',  page: 'diplomes'    },
  { label: 'Années d\'expérience', value: '3+', page: 'experience'  },
];

const contact = [
  { icon: '📍', text: 'Rouillac, Charente' },
  { icon: '✉️',  text: 'theo.feugnet@gmail.com' },
  { icon: '🚗', text: 'Permis B' },
];
---

<section id="about" class="page-section">
  <div class="max-w-5xl mx-auto w-full px-8 pt-24 pb-16">
  <AnimationWrapper>
    <SectionTitle id="about" label="À propos" comment="who_am_i.md" />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Bio -->
      <BentoCard class="md:col-span-2">
        <p class="font-mono text-xs mb-3" style="color: var(--accent-dim);">// README.md</p>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
          Inspiré par l’univers des jeux vidéo et de la science-fiction, je me suis tourné
          vers la programmation et l’électronique. Mon objectif est de concevoir des
          systèmes embarqués alliant le monde virtuel au monde réel.
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
          Mon terrain de jeu : les microcontrôleurs, la programmation bas niveau, 
          les protocoles de communication industriels et la conception PCB. 
          Je cherche à produire du code robuste et des circuits fiables qui 
          accomplissent exactement ce qu'on attend d'eux, sans compromis.
        </p>
        <!-- Stat chips -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-6">
          {stats.map((s) => (
            s.page ? (
              <button
                data-page={s.page}
                class="text-center p-2 rounded transition-all duration-200"
                style="background: var(--bg-surface-2); border: 1px solid var(--border); cursor: pointer;"
                onmouseover="this.style.borderColor='var(--accent-teal)'; this.style.background='var(--bg-surface)'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.background='var(--bg-surface-2)'"
              >
                <div class="font-mono text-lg font-bold" style="color: var(--accent-teal);">{s.value}</div>
                <div class="font-mono text-[10px]" style="color: var(--text-muted);">{s.label}</div>
              </button>
            ) : (
              <div
                class="text-center p-2 rounded"
                style="background: var(--bg-surface-2); border: 1px solid var(--border);"
              >
                <div class="font-mono text-lg font-bold" style="color: var(--accent-teal);">{s.value}</div>
                <div class="font-mono text-[10px]" style="color: var(--text-muted);">{s.label}</div>
              </div>
            )
          ))}
        </div>
      </BentoCard>

      <!-- Photo / contact -->
      <BentoCard padded={false} class="flex flex-col items-center justify-center min-h-48 overflow-hidden">
        <div class="text-center p-6 w-full">
          <img
            src="/theo.jpg"
            alt="Théo Feugnet"
            class="w-36 h-36 rounded-full mx-auto mb-4 object-cover"
            style="border: 2px solid var(--accent-dim);"
          />
          <p class="font-mono text-xs font-bold" style="color: var(--accent-teal);">Théo Feugnet</p>
          <p class="font-mono text-[10px] mt-1 mb-4" style="color: var(--text-muted);">Embedded Engineer</p>
          <div class="flex flex-col gap-1.5 text-left">
            {contact.map((c) => (
              <p class="font-mono text-[10px] flex gap-2 items-center" style="color: var(--text-secondary);">
                <span>{c.icon}</span><span>{c.text}</span>
              </p>
            ))}
          </div>
          <a
            href="/CV Théo Feugnet.pdf"
            download
            class="font-mono text-[10px] mt-4 px-3 py-1.5 rounded flex items-center justify-center gap-2 transition-all duration-200"
            style="border: 1px solid var(--border); color: var(--accent-teal); background: var(--bg-surface-2);"
            onmouseover="this.style.borderColor='var(--accent-teal)'; this.style.background='var(--bg-surface)'"
            onmouseout="this.style.borderColor='var(--border)'; this.style.background='var(--bg-surface-2)'"
          >
            ↓ Télécharger le CV
          </a>
        </div>
      </BentoCard>
    </div>

    <!-- CV intégré -->
    <BentoCard class="mt-4">
      <div class="flex items-center justify-between mb-3">
        <p class="font-mono text-xs" style="color: var(--accent-dim);">// curriculum_vitae.pdf</p>
        <a
          href="/CV Théo Feugnet.pdf"
          download
          class="font-mono text-[10px] px-3 py-1 rounded transition-all duration-200"
          style="border: 1px solid var(--border); color: var(--accent-teal); background: var(--bg-surface-2);"
          onmouseover="this.style.borderColor='var(--accent-teal)'; this.style.background='var(--bg-surface)'"
          onmouseout="this.style.borderColor='var(--border)'; this.style.background='var(--bg-surface-2)'"
        >
          ↓ Télécharger
        </a>
      </div>
      <iframe
        src="/CV Théo Feugnet.pdf"
        title="CV Théo Feugnet"
        class="w-full rounded"
        style="height: 680px; border: none; background: #fff;"
      ></iframe>
    </BentoCard>
  </AnimationWrapper>
  </div>
</section>
