---
import BentoCard from '../ui/BentoCard.astro';
import SectionTitle from '../ui/SectionTitle.astro';
import AnimationWrapper from '../ui/AnimationWrapper.astro';

const passions = [
  {
    id: 'cyberpunk',
    category: 'Jeux Vidéo',
    title: 'L\'univers du Cyberpunk',
    ref: 'Cyberpunk 2077 — CD Projekt Red',
    color: '#F59E0B',
    body: 'Grand fan du jeu vidéo Cyberpunk 2077 développé par le studio CD Projekt Red, cet univers a véritablement attisé mon amour pour la technologie et l\'électronique de par son ambiance futuriste, transhumaniste et aux teintes dystopiques.',
  },
  {
    id: 'fallout',
    category: 'Jeux Vidéo',
    title: 'L\'univers Post-Apocalyptique',
    ref: 'Fallout — Bethesda Softworks',
    color: '#4ADE80',
    body: 'Cette licence, nous présentant un monde apocalyptique post-guerre nucléaire, me tient beaucoup à cœur car elle réussit parfaitement à lier l\'ambiance des années 50 à une technologie très avancée, tout en conservant une forte sensation \"analogique\" de l\'électronique. C\'est d\'ailleurs cette saga qui m\'a poussé à fabriquer et reproduire l\'un de ses objets phares : le Pip-Boy.',
    pipboy: true,
  },
  {
    id: 'strategy',
    category: 'Jeux de Stratégie',
    title: 'Micro & Macro-Management',
    ref: 'Broken Arrow & Stellaris',
    color: '#A78BFA',
    body: 'Ces jeux me passionnent car ils me permettent d\'entraîner mes compétences en micro et macro-management, propres aux jeux de stratégie, tout en évoluant dans des mondes captivants. Ils m\'obligent à faire preuve de rigueur et à prendre des décisions cruciales au fur et à mesure de la partie, au risque de perdre de précieuses ressources.',
  },
];
---

<section id="passions" class="page-section">
  <div class="max-w-5xl mx-auto w-full px-8 pt-24 pb-16">
    <AnimationWrapper>
      <SectionTitle id="passions" label="Passions" comment="interests.json" />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {passions.map((p) => (
          <BentoCard class={`flex flex-col gap-3 ${p.id === 'strategy' ? 'md:col-span-2' : ''}`}>
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="font-mono text-[10px] mb-0.5" style="color: var(--text-muted);">{p.ref}</p>
                <h3 class="font-mono text-sm font-bold" style="color: var(--text-primary);">{p.title}</h3>
              </div>
              <span
                class="font-mono text-[9px] px-2 py-0.5 rounded shrink-0"
                style={`background: ${p.color}18; color: ${p.color}; border: 1px solid ${p.color}40;`}
              >
                {p.category}
              </span>
            </div>

            <div class="w-8 h-px" style={`background: ${p.color};`}></div>

            {p.id === 'cyberpunk' && (
              <img src="/Cyberpunk.gif" alt="Cyberpunk" class="w-full rounded object-cover" style="max-height: 180px;" />
            )}
            <p class="text-xs leading-relaxed" style="color: var(--text-secondary);">{p.body}</p>

            {p.pipboy && (
              <p class="font-mono text-[10px] mt-1">
                <span style="color: #4ADE80;">▸</span>{' '}
                <button data-page="projects" class="font-mono text-[10px]" style="color: var(--accent-teal); text-decoration: underline; background: none; border: none; cursor: pointer; padding: 0;">
                  Voir le projet Pip-Boy →
                </button>
              </p>
            )}
          </BentoCard>
        ))}
      </div>
    </AnimationWrapper>
  </div>
</section>
